---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="首页 - Vote">
    <div class="text-center mb-20 animate-fade-in">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-3xl shadow-2xl shadow-blue-500/30 mb-8 animate-float">
            <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2L2 7l10 5 10-5-10-5zm0 3.84L18.03 7 12 10.16 5.97 7 12 5.84zM2 17l10 5 10-5M12 18.16l-6.03-3 6.03 3 6.03-3z" />
            </svg>
        </div>
        <h2 class="text-5xl md:text-6xl font-extrabold mb-6 text-balance">
            <span class="gradient-text">欢迎来到投票评分网站</span>
        </h2>
        <p class="text-xl text-slate-600 dark:text-slate-400 max-w-3xl mx-auto leading-relaxed">
            在这里，你可以创建话题，添加角色或项目，并邀请其他人进行评分和点评。
            我们提供了直观易用的界面和强大的评分系统，让你的投票活动更加高效和有趣。
        </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <div class="card p-8 group cursor-pointer animate-fade-in-up animation-delay-100">
            <div class="relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-blue-400 to-indigo-500 rounded-full opacity-10 -mr-16 -mt-16 group-hover:scale-150 transition-transform duration-500"></div>
                
                <div class="relative z-10">
                    <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-blue-500/30 group-hover:shadow-blue-500/50 group-hover:scale-110 transition-all duration-300">
                        <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold mb-4 text-slate-800 dark:text-slate-100">创建话题</h3>
                    <p class="text-slate-600 dark:text-slate-400 mb-6 leading-relaxed">
                        轻松发起一个新的话题，自定义评分规则和维度，让你的投票活动更加个性化。
                    </p>
                    <a href="/create-topic" class="btn btn-primary w-full justify-center group-hover:shadow-xl">
                        <span>立即创建</span>
                        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                        </svg>
                    </a>
                </div>
            </div>
        </div>
        
        <div class="card p-8 group cursor-pointer animate-fade-in-up animation-delay-200">
            <div class="relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-emerald-400 to-teal-500 rounded-full opacity-10 -mr-16 -mt-16 group-hover:scale-150 transition-transform duration-500"></div>
                
                <div class="relative z-10">
                    <div class="w-16 h-16 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-emerald-500/30 group-hover:shadow-emerald-500/50 group-hover:scale-110 transition-all duration-300">
                        <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold mb-4 text-slate-800 dark:text-slate-100">浏览话题</h3>
                    <p class="text-slate-600 dark:text-slate-400 mb-6 leading-relaxed">
                        发现热门话题，参与评分和讨论，了解大家的看法和评价。
                    </p>
                    <a href="/topics" class="btn btn-success w-full justify-center group-hover:shadow-xl">
                        <span>浏览话题</span>
                        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </a>
                </div>
            </div>
        </div>
        
        <div class="card p-8 group cursor-pointer animate-fade-in-up animation-delay-300">
            <div class="relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-purple-400 to-pink-500 rounded-full opacity-10 -mr-16 -mt-16 group-hover:scale-150 transition-transform duration-500"></div>
                
                <div class="relative z-10">
                    <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-pink-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-purple-500/30 group-hover:shadow-purple-500/50 group-hover:scale-110 transition-all duration-300">
                        <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M17 3H7c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H7V5h10v14z" />
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold mb-4 text-slate-800 dark:text-slate-100">我的评分</h3>
                    <p class="text-slate-600 dark:text-slate-400 mb-6 leading-relaxed">
                        查看和管理我参与过的评分记录，追踪评分结果和变化趋势。
                    </p>
                    <a href="/topics" class="btn bg-gradient-to-r from-purple-600 to-pink-600 text-white shadow-lg shadow-purple-500/30 hover:shadow-xl hover:shadow-purple-500/40 w-full justify-center group-hover:shadow-xl">
                        <span>查看记录</span>
                        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="glass-card p-8 md:p-12 animate-fade-in-up animation-delay-400">
        <div class="text-center mb-8">
            <h3 class="text-3xl font-bold gradient-text mb-4">为什么选择 Vote？</h3>
            <p class="text-slate-600 dark:text-slate-400">简单、高效、有趣的投票体验</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <div class="text-center p-4">
                <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/50 rounded-xl flex items-center justify-center mx-auto mb-4">
                    <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </div>
                <h4 class="font-semibold text-slate-800 dark:text-slate-200 mb-2">快速创建</h4>
                <p class="text-sm text-slate-600 dark:text-slate-400">几秒钟内创建话题</p>
            </div>
            <div class="text-center p-4">
                <div class="w-12 h-12 bg-emerald-100 dark:bg-emerald-900/50 rounded-xl flex items-center justify-center mx-auto mb-4">
                    <svg class="w-6 h-6 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <h4 class="font-semibold text-slate-800 dark:text-slate-200 mb-2">易于使用</h4>
                <p class="text-sm text-slate-600 dark:text-slate-400">直观的用户界面</p>
            </div>
            <div class="text-center p-4">
                <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/50 rounded-xl flex items-center justify-center mx-auto mb-4">
                    <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                </div>
                <h4 class="font-semibold text-slate-800 dark:text-slate-200 mb-2">社区互动</h4>
                <p class="text-sm text-slate-600 dark:text-slate-400">分享和讨论观点</p>
            </div>
            <div class="text-center p-4">
                <div class="w-12 h-12 bg-amber-100 dark:bg-amber-900/50 rounded-xl flex items-center justify-center mx-auto mb-4">
                    <svg class="w-6 h-6 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                </div>
                <h4 class="font-semibold text-slate-800 dark:text-slate-200 mb-2">安全可靠</h4>
                <p class="text-sm text-slate-600 dark:text-slate-400">数据安全存储</p>
            </div>
        </div>
    </div>
</MainLayout>
