---
import Navigation from '../components/app/Navigation';
const { title = 'Vote - 让投票评分变得简单有趣' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content="Vote - 一个现代化的投票评分平台，支持创建话题、多维度评分、实时评论等功能">
    <link rel="stylesheet" href="/src/styles/globals.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen text-slate-900 dark:text-slate-100">
    <header class="fixed top-4 left-4 right-4 z-50">
        <div class="glass rounded-2xl shadow-xl">
            <div class="container mx-auto px-6 py-4 flex justify-between items-center">
                <a href="/" class="flex items-center gap-3 group">
                    <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-xl flex items-center justify-center shadow-lg shadow-blue-500/30 group-hover:shadow-blue-500/50 transition-shadow duration-300">
                        <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 2L2 7l10 5 10-5-10-5zm0 3.84L18.03 7 12 10.16 5.97 7 12 5.84zM2 17l10 5 10-5M12 18.16l-6.03-3 6.03 3 6.03-3z" />
                        </svg>
                    </div>
                    <h1 class="text-2xl font-bold gradient-text">Vote</h1>
                </a>
                <Navigation client:load />
            </div>
        </div>
    </header>
    
    <main class="container mx-auto px-4 pt-28 pb-16">
        <slot />
    </main>
    
    <footer class="relative mt-16">
        <div class="absolute inset-0 bg-gradient-to-t from-slate-100 to-transparent dark:from-slate-900 pointer-events-none"></div>
        <div class="glass-card relative">
            <div class="container mx-auto px-6 py-12">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                    <div class="text-center md:text-left">
                        <div class="flex items-center justify-center md:justify-start gap-3 mb-4">
                            <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center shadow-lg">
                                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 2L2 7l10 5 10-5-10-5zm0 3.84L18.03 7 12 10.16 5.97 7 12 5.84zM2 17l10 5 10-5M12 18.16l-6.03-3 6.03 3 6.03-3z" />
                                </svg>
                            </div>
                            <h3 class="text-xl font-bold gradient-text">Vote</h3>
                        </div>
                        <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
                            让投票评分变得简单有趣<br>
                            创建话题，分享观点，发现精彩
                        </p>
                    </div>
                    <div class="text-center">
                        <h4 class="font-semibold mb-4 text-slate-800 dark:text-slate-200">快速链接</h4>
                        <ul class="space-y-3">
                            <li>
                                <a href="/" class="text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-200 inline-flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                                    </svg>
                                    首页
                                </a>
                            </li>
                            <li>
                                <a href="/topics" class="text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-200 inline-flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                                    </svg>
                                    话题
                                </a>
                            </li>
                            <li>
                                <a href="/create-topic" class="text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-200 inline-flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                                    </svg>
                                    创建话题
                                </a>
                            </li>
                        </ul>
                    </div>
                    <div class="text-center md:text-right">
                        <h4 class="font-semibold mb-4 text-slate-800 dark:text-slate-200">关于我们</h4>
                        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
                            © 2025 Vote<br>
                            保留所有权利
                        </p>
                        <div class="flex items-center justify-center md:justify-end gap-4 mt-4">
                            <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors duration-200">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </footer>
</body>
</html>
